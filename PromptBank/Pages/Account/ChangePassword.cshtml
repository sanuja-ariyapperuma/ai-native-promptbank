@page
@model PromptBank.Pages.Account.ChangePasswordModel
@{
    ViewData["Title"] = "Change Password";
}

<div class="row justify-content-center">
    <div class="col-12" style="max-width:440px;">

        <div class="card shadow-sm pb-card-form">
            <div class="card-header py-3 pb-card-header">
                <h1 class="h4 fw-bold mb-0 pb-primary-text">
                    <i class="bi bi-key me-2"></i>Change Password
                </h1>
            </div>
            <div class="card-body p-4">
                <div class="alert alert-warning mb-3" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    You must set a new password before continuing.
                </div>

                <form method="post">
                    <input type="hidden" asp-for="ReturnUrl" />
                    <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="Input.CurrentPassword" class="form-label fw-semibold">Current password</label>
                        <input asp-for="Input.CurrentPassword" class="form-control" autocomplete="current-password" autofocus />
                        <span asp-validation-for="Input.CurrentPassword" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.NewPassword" class="form-label fw-semibold">New password</label>
                        <input asp-for="Input.NewPassword" class="form-control" autocomplete="new-password" />
                        <span asp-validation-for="Input.NewPassword" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.ConfirmPassword" class="form-label fw-semibold">Confirm new password</label>
                        <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" />
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-check-circle me-1"></i>Set New Password
                    </button>
                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
